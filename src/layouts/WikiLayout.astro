---
import '../styles/global.css';
import siteConfig from '../data/site-config.json';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  hasDualMode?: boolean;
}

const {
  title,
  description = "Base de conocimiento técnico personal sobre redes, sistemas, ciberseguridad, cloud y programación.",
  image = "/android-chrome-512x512.png",
  canonicalURL = Astro.url.href,
  hasDualMode = false,
} = Astro.props;

const SITE_NAME = "Knowledge Base";
const SITE_URL  = "https://kb.villaarreola.com";

// Build slug → name map for breadcrumb labels
const catMap: Record<string, { name: string; sections: Record<string, string> }> = {};
for (const cat of siteConfig.categories) {
  catMap[cat.slug] = { name: cat.name, sections: {} };
  for (const sec of (cat.sections || [])) {
    catMap[cat.slug].sections[sec.slug] = sec.name;
  }
}
---

<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | {SITE_NAME}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalURL}>

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#0f172a">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content={SITE_NAME}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={`${title} | ${SITE_NAME}`}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={`${SITE_URL}${image}`}>
  <meta property="og:image:width" content="512">
  <meta property="og:image:height" content="512">
  <meta property="og:locale" content="es_ES">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={`${title} | ${SITE_NAME}`}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={`${SITE_URL}${image}`}>

  <!-- Fonts: Outfit (display) + JetBrains Mono (code) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Always use dark mode -->
  <script is:inline>
    document.documentElement.classList.add('dark');
  </script>
</head>

<body class="h-full bg-slate-950 text-slate-100 antialiased">
  <div class="min-h-screen flex flex-col">

    <div id="kb-page-bar"
         class="view-mode-bar"
         data-dual-mode={hasDualMode ? 'true' : 'false'}
         data-page-title={title}
         data-cat-map={JSON.stringify(catMap)}>
      <div class="view-mode-inner">
        <a href="/" class="bar-brand" aria-label="Knowledge Base">
          <img src="/android-chrome-192x192.png" alt="Knowledge Base" class="bar-brand-icon" />
          <span class="bar-brand-text">Knowledge Base</span>
        </a>

        <nav class="page-breadcrumb" aria-label="Ubicación actual"></nav>

        <div class="page-tools">
          <div class="bar-search-wrap">
            <label class="bar-search" for="kbPageSearch" aria-label="Buscar en la base de conocimiento">
              <svg class="bar-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-5.2-5.2m1.7-4.3a6 6 0 11-12 0 6 6 0 0112 0z" />
              </svg>
              <input id="kbPageSearch" type="text" placeholder="Buscar en la KB..." autocomplete="off" />
            </label>
            <div id="kbBarSearchResults" class="kb-bar-search-results" style="display:none"></div>
          </div>

          <a href="https://cheats.villaarreola.com" class="bar-link-btn" target="_blank" rel="noopener" title="Cheat Sheets">🔎</a>
          <a href="https://ctf.villaarreola.com" class="bar-link-btn" target="_blank" rel="noopener" title="CTF WriteUps">📝</a>

          <div class="mode-toggle">
            <button class="mode-btn" data-view="markdown">Markdown</button>
            <button class="mode-btn" data-view="enriched">Interactivo</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast notification -->
    <div id="kb-toast" role="status" aria-live="polite"></div>

    <!-- Main Content -->
    <main class="flex-1 w-full max-w-5xl mx-auto px-3 sm:px-5 lg:px-8 py-5 sm:py-8">
      <article class="wiki-card">
        <slot />
      </article>
    </main>

    <!-- Footer (slim) -->
    <footer class="wiki-footer">
      <div class="wiki-footer-inner">
        <span>&copy; {new Date().getFullYear()} Knowledge Base</span>
        <nav class="wiki-footer-links">
          <a href="/">Inicio</a>
          <a href="https://cheats.villaarreola.com" target="_blank" rel="noopener">Cheat Sheets</a>
          <a href="https://ctf.villaarreola.com" target="_blank" rel="noopener">CTF</a>
        </nav>
      </div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      var bar = document.getElementById('kb-page-bar');
      if (!bar) return;

      var isDualMode = bar.dataset.dualMode === 'true';
      var pageTitle  = bar.dataset.pageTitle || '';
      var catMap = {};
      try { catMap = JSON.parse(bar.dataset.catMap || '{}'); } catch (e) {}

      // ── Breadcrumb ─────────────────────────────────────────
      var bc = bar.querySelector('.page-breadcrumb');
      if (bc) {
        var parts = window.location.pathname.replace(/^\/|\/$/g, '').split('/').filter(Boolean);
        if (parts.length > 0) {
          var html = '';
          var path = '';
          var catEntry = catMap[parts[0]] || null;
          for (var i = 0; i < parts.length; i++) {
            if (i > 0) html += '<span class="bc-sep">›</span>';
            path += '/' + parts[i];
            var isLast = i === parts.length - 1;
            var label;
            if (i === 0) {
              label = catEntry ? catEntry.name : cap(parts[i]);
            } else if (i === 1 && catEntry) {
              label = catEntry.sections[parts[i]] || cap(parts[i]);
            } else if (isLast) {
              label = pageTitle.replace(/^[^\w\s\u00C0-\u024F]+\s*/, '').trim() || cap(parts[i]);
            } else {
              label = cap(parts[i]);
            }
            if (isLast) {
              html += '<span class="bc-item bc-current">' + esc(label) + '</span>';
            } else {
              var href = (i === 1) ? '/' + parts[0] : path;
              html += '<a class="bc-item" href="' + href + '">' + esc(label) + '</a>';
            }
          }
          bc.innerHTML = html;
        }
      }

      // ── Toast ──────────────────────────────────────────────
      var toast = document.getElementById('kb-toast');
      var toastTimer;
      function showToast(msg) {
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.add('visible');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(function () { toast.classList.remove('visible'); }, 2500);
      }

      // ── View switching ─────────────────────────────────────
      var saved = localStorage.getItem('kb-view-mode') || 'enriched';

      // ── Page bar search (standalone) ───────────────────────
      var barSearchInput = document.getElementById('kbPageSearch');
      var barSearchResults = document.getElementById('kbBarSearchResults');
      var barSearchWrap = bar ? bar.querySelector('.bar-search-wrap') : null;
      var searchIndex = [];

      function loadSearchIndex() {
        if (searchIndex.length > 0) return Promise.resolve(searchIndex);
        return fetch('/search-index.json')
          .then(function (res) { return res.json(); })
          .then(function (data) {
            searchIndex = (data && data.pages) ? data.pages : [];
            return searchIndex;
          })
          .catch(function () {
            searchIndex = [];
            return searchIndex;
          });
      }

      function hideBarSearchResults() {
        if (!barSearchResults) return;
        barSearchResults.style.display = 'none';
        barSearchResults.innerHTML = '';
      }

      function renderBarSearchResults(results) {
        if (!barSearchResults) return;

        if (!results.length) {
          barSearchResults.innerHTML = '<div class="kb-search-empty">Sin resultados</div>';
          barSearchResults.style.display = 'block';
          return;
        }

        var html = '';
        for (var i = 0; i < results.length; i++) {
          var page = results[i];
          html +=
            '<a class="kb-search-item" href="' + page.url + '">' +
              '<span class="kb-search-item-title">' + esc((page.icon || '📄') + ' ' + (page.title || 'Sin título')) + '</span>' +
              '<span class="kb-search-item-meta">' + esc((page.category || '') + (page.section ? ' / ' + page.section : '')) + '</span>' +
            '</a>';
        }

        barSearchResults.innerHTML = html;
        barSearchResults.style.display = 'block';
      }

      if (barSearchInput && barSearchResults) {
        loadSearchIndex();

        barSearchInput.addEventListener('input', function () {
          var query = barSearchInput.value.trim().toLowerCase();
          if (query.length < 2) {
            hideBarSearchResults();
            return;
          }

          loadSearchIndex().then(function (pages) {
            var matches = pages
              .filter(function (p) {
                var tags = Array.isArray(p.tags) ? p.tags.join(' ') : '';
                var haystack = ((p.title || '') + ' ' + (p.description || '') + ' ' + tags + ' ' + (p.category || '') + ' ' + (p.section || '')).toLowerCase();
                return haystack.indexOf(query) !== -1;
              })
              .slice(0, 6);

            renderBarSearchResults(matches);
          });
        });

        barSearchInput.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') {
            var first = barSearchResults.querySelector('.kb-search-item');
            if (first && first.getAttribute('href')) {
              window.location.href = first.getAttribute('href');
            }
          } else if (e.key === 'Escape') {
            hideBarSearchResults();
          }
        });

        document.addEventListener('click', function (e) {
          if (!barSearchWrap) return;
          if (!barSearchWrap.contains(e.target)) {
            hideBarSearchResults();
          }
        });
      }

      function setActiveBtn(v) {
        document.querySelectorAll('.mode-btn').forEach(function (btn) {
          btn.classList.toggle('active', btn.dataset.view === v);
        });
      }

      function applyView(v) {
        if (!isDualMode) {
          setActiveBtn('markdown');
          if (v === 'enriched') showToast('No disponible para esta sección');
          return;
        }
        document.querySelectorAll('[data-view]:not(.mode-btn)').forEach(function (el) {
          el.style.display = el.dataset.view === v ? '' : 'none';
        });
        setActiveBtn(v);
        localStorage.setItem('kb-view-mode', v);
      }

      // Init
      isDualMode ? applyView(saved) : setActiveBtn('markdown');

      document.querySelectorAll('.mode-btn').forEach(function (btn) {
        btn.addEventListener('click', function () { applyView(btn.dataset.view); });
      });

      function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1).replace(/-/g, ' '); }
      function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    })();
  </script>
</body>
</html>

<style>
  body {
    font-family: 'Outfit', 'Segoe UI', system-ui, sans-serif;
  }

  /* ── Wiki content card ─────────────────────────────── */
  .wiki-card {
    background: rgba(15, 23, 42, 0.9);
    border: 1px solid rgba(148, 163, 184, 0.1);
    border-radius: 0.875rem;
    padding: 1.25rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  @media (min-width: 640px) {
    .wiki-card { padding: 1.75rem; }
  }

  @media (min-width: 1024px) {
    .wiki-card { padding: 2.25rem; }
  }

  /* ── Page bar (breadcrumb + mode toggle) ───────────── */
  .view-mode-bar {
    background:
      linear-gradient(90deg, rgba(12, 19, 34, 0.92), rgba(16, 25, 44, 0.9) 45%, rgba(17, 33, 54, 0.92)),
      radial-gradient(900px 140px at 30% -30px, rgba(56, 189, 248, 0.14), transparent 65%);
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(14px);
  }

  .view-mode-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.56rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
  }

  .bar-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    text-decoration: none;
    color: #e2e8f0;
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 999px;
    padding: 0.22rem 0.52rem 0.22rem 0.26rem;
    flex-shrink: 0;
  }

  .bar-brand-icon {
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 0.35rem;
  }

  .bar-brand-text {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  /* Breadcrumb */
  .page-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .bc-item {
    font-size: 0.8rem;
    color: rgba(125, 211, 252, 0.75);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .bc-item:hover {
    color: rgba(186, 230, 253, 0.95);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(125, 211, 252, 0.4);
  }

  .bc-current {
    font-size: 0.88rem;
    color: rgba(241, 245, 249, 0.94);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 520px;
  }

  .bc-sep {
    font-size: 0.74rem;
    color: rgba(148, 163, 184, 0.45);
    user-select: none;
  }



  .page-tools {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .bar-search-wrap {
    position: relative;
  }

  .bar-search {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    height: 2rem;
    padding: 0 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.24);
    background: linear-gradient(120deg, rgba(15, 23, 42, 0.8), rgba(30, 41, 59, 0.68));
    color: rgba(148, 163, 184, 0.78);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .bar-search:focus-within {
    border-color: rgba(34, 211, 238, 0.55);
    box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.16);
  }

  .bar-search-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .bar-search input {
    width: 11.5rem;
    border: none;
    background: transparent;
    color: #e2e8f0;
    font-size: 0.78rem;
    font-family: 'JetBrains Mono', monospace;
    outline: none;
  }

  .bar-search input::placeholder {
    color: rgba(148, 163, 184, 0.66);
  }

  .kb-bar-search-results {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 0;
    width: min(24rem, calc(100vw - 2rem));
    max-height: 20rem;
    overflow-y: auto;
    border-radius: 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    background: linear-gradient(120deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.95));
    box-shadow: 0 16px 35px rgba(2, 6, 23, 0.55);
    z-index: 80;
  }

  .kb-search-item {
    display: block;
    text-decoration: none;
    padding: 0.58rem 0.72rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .kb-search-item:last-child {
    border-bottom: none;
  }

  .kb-search-item:hover {
    background: rgba(99, 102, 241, 0.17);
  }

  .kb-search-item-title {
    display: block;
    font-size: 0.78rem;
    color: #e2e8f0;
    font-weight: 600;
  }

  .kb-search-item-meta {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.68rem;
    color: rgba(148, 163, 184, 0.86);
    text-transform: capitalize;
  }

  .kb-search-empty {
    padding: 0.7rem 0.8rem;
    font-size: 0.74rem;
    color: rgba(148, 163, 184, 0.85);
  }

  .bar-link-btn {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.23);
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
    color: rgba(226, 232, 240, 0.9);
    text-decoration: none;
    font-size: 0.8rem;
    flex-shrink: 0;
    cursor: pointer;
  }

  .bar-link-btn:hover {
    border-color: rgba(125, 211, 252, 0.55);
    background: rgba(56, 189, 248, 0.18);
  }

  /* Mode toggle group */
  .mode-toggle {
    display: flex;
    gap: 0.34rem;
    flex-shrink: 0;
    padding: 0.16rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    background: linear-gradient(120deg, rgba(15, 23, 42, 0.72), rgba(30, 41, 59, 0.48));
  }

  .mode-btn {
    padding: 0.34rem 0.82rem;
    border-radius: 2rem;
    border: 1px solid transparent;
    background: transparent;
    color: rgba(148, 163, 184, 0.8);
    font-size: 0.78rem;
    font-weight: 600;
    font-family: 'Outfit', 'Segoe UI', sans-serif;
    cursor: pointer;
    transition: all 0.18s ease;
  }

  .mode-btn:hover {
    background: rgba(148, 163, 184, 0.13);
    color: #e2e8f0;
  }

  .mode-btn.active {
    background: linear-gradient(120deg, rgba(99, 102, 241, 0.34), rgba(34, 211, 238, 0.25));
    border-color: rgba(125, 211, 252, 0.5);
    color: #dbeafe;
    box-shadow: 0 0 12px rgba(56, 189, 248, 0.18);
  }

  @media (max-width: 1024px) {
    .bar-search input {
      width: 9.5rem;
    }

    .bc-current {
      max-width: 380px;
    }

    .bar-brand-text {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .view-mode-inner {
      flex-wrap: wrap;
      row-gap: 0.3rem;
      padding-top: 0.45rem;
      padding-bottom: 0.45rem;
      align-items: center;
    }

    /* Row 1: brand left, tools right */
    .bar-brand {
      order: 1;
      flex-shrink: 0;
    }

    .page-tools {
      order: 1;
      margin-left: auto;
      gap: 0.35rem;
    }

    /* Row 2: breadcrumb full width, scrollable */
    .page-breadcrumb {
      order: 2;
      flex-basis: 100%;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .page-breadcrumb::-webkit-scrollbar {
      display: none;
    }

    .bar-search-wrap {
      display: none;
    }

    .bar-link-btn {
      display: none;
    }

    /* Keep the pill style on mobile */
    .mode-toggle {
      padding: 0.14rem;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background: linear-gradient(120deg, rgba(15, 23, 42, 0.72), rgba(30, 41, 59, 0.48));
      gap: 0.2rem;
    }

    .mode-btn {
      padding: 0.26rem 0.65rem;
      font-size: 0.73rem;
    }

    /* No truncation — breadcrumb scrolls horizontally */
    .bc-item {
      font-size: 0.72rem;
      max-width: none;
      white-space: nowrap;
    }

    .bc-current {
      max-width: none;
      font-size: 0.78rem;
      white-space: nowrap;
      overflow: visible;
      text-overflow: unset;
    }
  }

  @media (max-width: 520px) {
    /* Show only the icon, hide the text label */
    .bar-brand-text {
      display: none;
    }

    .page-tools {
      margin-left: auto;
      gap: 0.32rem;
    }

    .view-mode-inner {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    .mode-btn {
      font-size: 0.71rem;
      padding: 0.24rem 0.56rem;
    }

    .bc-item {
      font-size: 0.69rem;
    }

    .bc-current {
      font-size: 0.73rem;
    }
  }

  /* Toast */
  #kb-toast {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(0.5rem);
    background: rgba(30, 41, 59, 0.96);
    border: 1px solid rgba(148, 163, 184, 0.2);
    color: #e2e8f0;
    font-size: 0.83rem;
    font-family: 'Outfit', sans-serif;
    padding: 0.5rem 1.1rem;
    border-radius: 2rem;
    opacity: 0;
    pointer-events: none;
    z-index: 9999;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }

  #kb-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── Footer ────────────────────────────────────────── */
  .wiki-footer {
    background: linear-gradient(135deg, #0f172a, #1e293b);
    border-top: 1px solid rgba(148, 163, 184, 0.08);
    padding: 1.25rem 0;
    margin-top: auto;
  }

  .wiki-footer-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: rgba(148, 163, 184, 0.5);
    text-align: center;
  }

  @media (min-width: 640px) {
    .wiki-footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .wiki-footer-links {
    display: flex;
