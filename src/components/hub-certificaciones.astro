---
const certs = [
  {
    name: 'CompTIA Security+',
    code: 'SY0-701',
    icon: '🛡️',
    href: '/cert/SY0-701',
    accent: '#e74c3c',
    glow: 'rgba(231,76,60,0.18)',
    status: 'En Estudio',
    statusType: 'active',
    progress: 75,
    topics: [
      { label: 'Criptografía',    state: 'done'    },
      { label: 'CIA Triad',       state: 'done'    },
      { label: 'PKI',             state: 'current' },
      { label: 'Network Security',state: 'pending' },
    ],
  },
  {
    name: 'Fortinet NSE 4',
    code: 'NSE4_FGT-7.2',
    icon: '🔥',
    href: '/cert/NSE4_FGT-7.2',
    accent: '#ee5a24',
    glow: 'rgba(238,90,36,0.18)',
    status: 'Considerando',
    statusType: 'pending',
    progress: 10,
    topics: [
      { label: 'FortiGate Admin', state: 'pending' },
      { label: 'Security Policies',state: 'pending'},
      { label: 'VPN Config',      state: 'pending' },
      { label: 'Threat Protection',state: 'pending'},
    ],
  },
  {
    name: 'Azure AI Fundamentals',
    code: 'AI-900',
    icon: '☁️',
    href: '/cert/AI-900',
    accent: '#0078d4',
    glow: 'rgba(0,120,212,0.18)',
    status: 'Futuro',
    statusType: 'future',
    progress: 5,
    topics: [
      { label: 'AI Workloads',    state: 'pending' },
      { label: 'Machine Learning',state: 'pending' },
      { label: 'Computer Vision', state: 'pending' },
      { label: 'NLP',             state: 'pending' },
    ],
  },
  {
    name: 'Cisco CCNA',
    code: '200-301',
    icon: '🌐',
    href: '/cert/200-301',
    accent: '#049fd9',
    glow: 'rgba(4,159,217,0.18)',
    status: 'Largo Plazo',
    statusType: 'future',
    progress: 0,
    topics: [
      { label: 'Net Fundamentals',state: 'pending' },
      { label: 'Routing/Switching',state:'pending' },
      { label: 'IP Connectivity',  state: 'pending' },
      { label: 'Security',         state: 'pending' },
    ],
  },
  {
    name: 'CFE',
    code: 'Forensic Examiner',
    icon: '🔍',
    href: '/cert/CFE',
    accent: '#8e44ad',
    glow: 'rgba(142,68,173,0.18)',
    status: 'Planificado',
    statusType: 'planned',
    progress: 25,
    topics: [
      { label: 'Digital Forensics',state: 'current'},
      { label: 'Evidence Analysis', state: 'pending'},
      { label: 'Legal Procedures',  state: 'pending'},
      { label: 'Report Writing',    state: 'pending'},
    ],
  },
  {
    name: 'AWS Cloud Practitioner',
    code: 'CLF-C02',
    icon: '📦',
    href: '/cert/CLF-C02',
    accent: '#ff9900',
    glow: 'rgba(255,153,0,0.18)',
    status: 'En Evaluación',
    statusType: 'pending',
    progress: 0,
    topics: [
      { label: 'Cloud Concepts',   state: 'pending' },
      { label: 'Security',         state: 'pending' },
      { label: 'Technology',       state: 'pending' },
      { label: 'Billing',          state: 'pending' },
    ],
  },
];

const stateIcon: Record<string, string> = {
  done:    '✓',
  current: '▶',
  pending: '·',
};
---

<div class="cert-grid">
  {certs.map((cert) => (
    <a
      class="cert-card"
      href={cert.href}
      style={`--accent: ${cert.accent}; --glow: ${cert.glow};`}
    >
      <!-- top accent line -->
      <div class="cert-stripe"></div>

      <div class="cert-head">
        <span class="cert-icon">{cert.icon}</span>
        <div class="cert-meta">
          <span class="cert-name">{cert.name}</span>
          <span class="cert-code">{cert.code}</span>
        </div>
        <span class={`cert-badge cert-badge--${cert.statusType}`}>{cert.status}</span>
      </div>

      <!-- progress -->
      <div class="cert-progress">
        <div class="prog-track">
          <div class="prog-fill" style={`width: ${cert.progress}%`}></div>
        </div>
        <span class="prog-label">{cert.progress}%</span>
      </div>

      <!-- topics -->
      <div class="cert-topics">
        {cert.topics.map((t) => (
          <span class={`topic topic--${t.state}`}>
            <span class="topic-dot">{stateIcon[t.state]}</span>
            {t.label}
          </span>
        ))}
      </div>
    </a>
  ))}
</div>

<style>
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  .cert-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 18px 16px 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .cert-card:hover {
    background: rgba(255,255,255,0.055);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.1), 0 10px 28px var(--glow);
    transform: translateY(-2px);
  }

  /* top stripe */
  .cert-stripe {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .cert-card:hover .cert-stripe { opacity: 1; }

  /* header */
  .cert-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 2px;
  }

  .cert-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .cert-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .cert-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #e2e8f0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cert-code {
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(100,116,139,0.9);
    font-family: monospace;
    letter-spacing: 0.04em;
  }

  /* status badge */
  .cert-badge {
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .cert-badge--active {
    background: rgba(96,165,250,0.15);
    color: #93c5fd;
    border: 1px solid rgba(96,165,250,0.25);
  }

  .cert-badge--planned {
    background: rgba(192,132,252,0.15);
    color: #d8b4fe;
    border: 1px solid rgba(192,132,252,0.25);
  }

  .cert-badge--future {
    background: rgba(74,222,128,0.12);
    color: #86efac;
    border: 1px solid rgba(74,222,128,0.2);
  }

  .cert-badge--pending {
    background: rgba(251,146,60,0.12);
    color: #fdba74;
    border: 1px solid rgba(251,146,60,0.2);
  }

  /* progress */
  .cert-progress {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .prog-track {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .prog-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 4px;
    opacity: 0.8;
    transition: width 1s ease-out;
  }

  .prog-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(100,116,139,0.8);
    width: 28px;
    text-align: right;
    flex-shrink: 0;
  }

  /* topics */
  .cert-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .topic {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.7rem;
    padding: 3px 8px;
    border-radius: 5px;
    font-weight: 500;
  }

  .topic-dot {
    font-size: 0.6rem;
    line-height: 1;
  }

  .topic--done {
    background: rgba(74,222,128,0.1);
    color: #86efac;
    border: 1px solid rgba(74,222,128,0.18);
  }

  .topic--done .topic-dot { color: #4ade80; }

  .topic--current {
    background: rgba(251,191,36,0.1);
    color: #fde68a;
    border: 1px solid rgba(251,191,36,0.2);
    animation: pulse-current 2s ease-in-out infinite;
  }

  .topic--current .topic-dot { color: #fbbf24; }

  .topic--pending {
    background: rgba(255,255,255,0.03);
    color: rgba(100,116,139,0.7);
    border: 1px solid rgba(255,255,255,0.06);
  }

  @keyframes pulse-current {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.7; }
  }

  @media (max-width: 640px) {
    .cert-grid { grid-template-columns: 1fr; }
  }
</style>
