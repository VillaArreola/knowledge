<style>
  .modern-navbar {
    background:
      radial-gradient(1200px 300px at 50% -120px, rgba(56, 189, 248, 0.2), transparent 60%),
      linear-gradient(120deg, #0b1220 0%, #111a2e 45%, #1b2740 100%);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    position: sticky;
    top: 0;
    z-index: 80;
    isolation: isolate;
  }

  .modern-navbar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.03), transparent);
    pointer-events: none;
  }

  .navbar-border {
    height: 2px;
    background: linear-gradient(90deg, #22d3ee 0%, #f59e0b 35%, #34d399 70%, #22d3ee 100%);
    background-size: 180% 100%;
    animation: shimmer 5s linear infinite;
    opacity: 0.9;
  }

  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50%       { background-position: 100% 50%; }
  }

  .navbar-inner {
    max-width: 1360px;
    margin: 0 auto;
    padding: 0.75rem 1rem;
    min-height: 72px;
    display: grid;
    grid-template-columns: minmax(180px, 1fr) minmax(320px, 560px) minmax(220px, 1fr);
    align-items: center;
    gap: 0.9rem;
    position: relative;
  }

  /* Brand */
  .brand-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    width: fit-content;
    justify-self: start;
    padding: 0.42rem 0.62rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02));
    text-decoration: none;
    flex-shrink: 0;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .brand-link:hover {
    border-color: rgba(125, 211, 252, 0.45);
    background: linear-gradient(120deg, rgba(56, 189, 248, 0.18), rgba(59, 130, 246, 0.07));
    transform: translateY(-1px);
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.55rem;
    background: rgba(15, 23, 42, 0.7);
    border: 1px solid rgba(125, 211, 252, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(8, 47, 73, 0.35);
  }

  .brand-text {
    color: #e2e8f0;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    background: linear-gradient(45deg, #f8fafc, #93c5fd);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    white-space: nowrap;
  }

  /* Search */
  .search-container {
    justify-self: center;
    width: 100%;
    max-width: 560px;
    min-width: 240px;
    position: relative;
    z-index: 2;
  }

  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    border-radius: 14px;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: linear-gradient(120deg, rgba(15, 23, 42, 0.82), rgba(30, 41, 59, 0.72));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 10px 24px rgba(2, 6, 23, 0.35);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .search-box:focus-within {
    border-color: rgba(34, 211, 238, 0.6);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 0 3px rgba(34, 211, 238, 0.2),
      0 14px 30px rgba(8, 47, 73, 0.45);
    transform: translateY(-1px);
  }

  .search-icon {
    position: absolute;
    left: 13px;
    width: 16px;
    height: 16px;
    color: rgba(148, 163, 184, 0.75);
    z-index: 2;
    flex-shrink: 0;
  }

  .search-box input {
    width: 100%;
    padding: 10px 72px 10px 39px;
    background: transparent;
    border: none;
    border-radius: 14px;
    color: #f1f5f9;
    font-size: 0.88rem;
    font-family: 'JetBrains Mono', 'Segoe UI', monospace;
    min-height: 42px;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .search-box input::placeholder { color: rgba(148, 163, 184, 0.62); }

  .search-box input:focus {
    outline: none;
    color: #f8fafc;
  }

  .search-shortcut {
    position: absolute;
    right: 9px;
    background: rgba(15, 23, 42, 0.8);
    color: rgba(147, 197, 253, 0.8);
    border: 1px solid rgba(125, 211, 252, 0.25);
    padding: 2px 7px;
    border-radius: 999px;
    font-size: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    pointer-events: none;
  }

  /* External nav links */
  .nav-links {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 0.45rem;
    flex-shrink: 0;
  }

  .nav-ext-link {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 0.5rem 0.68rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: linear-gradient(120deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
    text-decoration: none;
    color: rgba(226, 232, 240, 0.88);
    font-size: 0.76rem;
    font-weight: 600;
    min-height: 40px;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .nav-ext-link span:first-child {
    font-size: 0.85rem;
    line-height: 1;
  }

  .nav-ext-link:hover {
    background: linear-gradient(120deg, rgba(56, 189, 248, 0.2), rgba(59, 130, 246, 0.08));
    border-color: rgba(125, 211, 252, 0.45);
    color: #f1f5f9;
    transform: translateY(-1px);
  }

  @media (max-width: 1100px) {
    .navbar-inner {
      grid-template-columns: minmax(150px, 1fr) minmax(260px, 1.2fr) minmax(170px, 1fr);
    }

    .brand-text {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 900px) {
    .navbar-inner {
      grid-template-columns: auto 1fr auto;
      row-gap: 0.55rem;
      padding-top: 0.62rem;
      padding-bottom: 0.62rem;
    }

    .search-container {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-self: stretch;
      width: 100%;
      min-width: 0;
      max-width: none;
    }

    .search-box input {
      min-height: 40px;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 560px) {
    .navbar-inner {
      grid-template-columns: auto 1fr auto;
      padding-left: 0.72rem;
      padding-right: 0.72rem;
    }

    .brand-text {
      display: none;
    }

    .search-shortcut {
      display: none;
    }
  }
</style>

<script>
// ── Global search logic (runs on every page) ──────────────────────────────
let searchIndex: Array<{
  url: string;
  title: string;
  icon: string;
  description: string;
  category: string;
  tags: string[];
  certifications?: Array<{ code: string; weight: number; domain: string }>;
}> = [];

async function loadSearchIndex() {
  if (searchIndex.length > 0) return;
  try {
    const res = await fetch('/search-index.json');
    const data = await res.json();
    searchIndex = data.pages;
  } catch (e) {
    console.error('Error cargando índice de búsqueda:', e);
  }
}

function highlightSearchTerms(text: string, query: string) {
  if (!query || query.length < 2) return text;
  const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
  return text.replace(regex, '<mark class="search-highlight">$1</mark>');
}

function calculateRelevanceScore(page: typeof searchIndex[0], query: string) {
  const q = query.toLowerCase();
  let score = 0;
  if (page.title.toLowerCase() === q) score += 100;
  else if (page.title.toLowerCase().includes(q)) score += 50;
  const exactTag = page.tags.some(t => t.toLowerCase() === q);
  if (exactTag) score += 30;
  else if (page.tags.some(t => t.toLowerCase().includes(q))) score += 15;
  if (page.category.toLowerCase().includes(q)) score += 20;
  if (page.description.toLowerCase().includes(q)) score += 10;
  return score;
}

function performSearch(query: string) {
  if (!query || query.length < 2) {
    hideSearchResults();
    return [];
  }
  const q = query.toLowerCase();
  const results = searchIndex.filter(p =>
    p.title.toLowerCase().includes(q) ||
    p.description.toLowerCase().includes(q) ||
    p.tags.some(t => t.toLowerCase().includes(q)) ||
    p.category.toLowerCase().includes(q)
  );
  const ranked = results.map(p => ({
    ...p,
    relevanceScore: calculateRelevanceScore(p, q),
    highlightedTitle: highlightSearchTerms(p.title, query),
    highlightedDescription: highlightSearchTerms(p.description, query),
    matchedTags: p.tags.filter(t => t.toLowerCase().includes(q)).map(t => highlightSearchTerms(t, query)),
  }));
  ranked.sort((a, b) => b.relevanceScore - a.relevanceScore);
  return ranked.slice(0, 6);
}

function showSearchResults(results: ReturnType<typeof performSearch>) {
  let container = document.getElementById('searchResults');
  if (!container) {
    container = document.createElement('div');
    container.id = 'searchResults';
    container.className = 'search-results-modern';
    const searchContainer = document.querySelector('.search-container');
    if (searchContainer) searchContainer.appendChild(container);
    else return;
  }

  container.innerHTML = '';

  if (results.length === 0) {
    container.innerHTML = `
      <div class="search-result no-results">
        <div class="no-results-content">
          <div class="no-results-icon">🔍</div>
          <div class="no-results-text">
            <div class="no-results-title">No se encontraron resultados</div>
            <div class="no-results-description">Intenta con otros términos de búsqueda</div>
          </div>
        </div>
      </div>`;
    container.style.display = 'block';
    return;
  }

  const header = document.createElement('div');
  header.className = 'search-results-header';
  header.innerHTML = `<div class="results-count"><span class="count-number">${results.length}</span><span class="count-text">resultado${results.length !== 1 ? 's' : ''} encontrado${results.length !== 1 ? 's' : ''}</span></div>`;
  container.appendChild(header);

  const grouped: Record<string, typeof results> = {};
  results.forEach(r => { (grouped[r.category] = grouped[r.category] || []).push(r); });

  Object.entries(grouped).forEach(([cat, catResults]) => {
    if (Object.keys(grouped).length > 1) {
      const catHeader = document.createElement('div');
      catHeader.className = 'category-header';
      catHeader.innerHTML = `<div class="category-title">${cat}</div><div class="category-count">${catResults.length}</div>`;
      container!.appendChild(catHeader);
    }
    catResults.forEach((r, i) => {
      const a = document.createElement('a');
      a.href = r.url;
      a.className = `search-result${i === 0 && Object.keys(grouped).length === 1 ? ' first-result' : ''}`;
      const tagsHtml = r.matchedTags.length > 0
        ? `<div class="result-tags">${r.matchedTags.map(t => `<span class="result-tag">${t}</span>`).join('')}</div>`
        : '';
      const scoreClass = r.relevanceScore > 50 ? 'high' : r.relevanceScore > 20 ? 'medium' : 'low';
      a.innerHTML = `
        <div class="result-icon-container">
          <div class="result-icon">${r.icon}</div>
          <div class="relevance-indicator ${scoreClass}"></div>
        </div>
        <div class="result-content">
          <div class="result-title">${r.highlightedTitle}</div>
          <div class="result-category-badge">${r.category}</div>
          <div class="result-description">${r.highlightedDescription}</div>
          ${tagsHtml}
        </div>
        <div class="result-arrow">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>`;
      container!.appendChild(a);
    });
  });

  container.style.display = 'block';

  // Emit event so homepage can react
  document.dispatchEvent(new CustomEvent('search:results', { detail: results }));
}

function hideSearchResults() {
  const container = document.getElementById('searchResults');
  if (container) container.style.display = 'none';
  document.dispatchEvent(new CustomEvent('search:results', { detail: [] }));
}

function clearSearch() {
  const input = document.getElementById('searchInput') as HTMLInputElement | null;
  if (input) input.value = '';
  hideSearchResults();
}

function focusSearch() {
  const input = document.getElementById('searchInput') as HTMLInputElement | null;
  if (input) { input.focus(); input.select?.(); }
}

function initSearch() {
  const input = document.getElementById('searchInput') as HTMLInputElement | null;
  if (!input) return;

  input.addEventListener('input', async (e) => {
    const query = (e.target as HTMLInputElement).value.trim();
    await loadSearchIndex();
    if (query.length >= 2) {
      showSearchResults(performSearch(query));
    } else {
      hideSearchResults();
    }
  });

  input.addEventListener('keydown', (e) => {
    const container = document.getElementById('searchResults');
    if (!container || container.style.display === 'none') return;
    const items = container.querySelectorAll('.search-result:not(.no-results)');
    const current = container.querySelector('.search-result.active');
    let idx = current ? Array.from(items).indexOf(current) : -1;

    if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); }
    else if (e.key === 'Enter') {
      e.preventDefault();
      if (idx >= 0) {
        const href = (items[idx] as HTMLAnchorElement).href;
        if (href) window.location.href = href;
      }
      return;
    } else if (e.key === 'Escape') {
      clearSearch();
      input.blur();
      return;
    } else return;

    items.forEach((item, i) => item.classList.toggle('active', i === idx));
  });

  document.addEventListener('click', (e) => {
    const searchContainer = document.querySelector('.search-container');
    if (searchContainer && !searchContainer.contains(e.target as Node)) {
      hideSearchResults();
    }
  });
}

document.addEventListener('DOMContentLoaded', async () => {
  await loadSearchIndex();
  initSearch();

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      focusSearch();
    }
  });

});
</script>

