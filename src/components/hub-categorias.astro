---
import siteConfig from '../data/site-config.json';

const categories = siteConfig.categories || [];

const accentByBadge: Record<string, { color: string; glow: string }> = {
  indigo:  { color: '#818cf8', glow: 'rgba(129,140,248,0.2)' },
  blue:    { color: '#60a5fa', glow: 'rgba(96,165,250,0.2)'  },
  slate:   { color: '#94a3b8', glow: 'rgba(148,163,184,0.2)' },
  green:   { color: '#4ade80', glow: 'rgba(74,222,128,0.2)'  },
  orange:  { color: '#fb923c', glow: 'rgba(251,146,60,0.2)'  },
  purple:  { color: '#c084fc', glow: 'rgba(192,132,252,0.2)' },
  gray:    { color: '#9ca3af', glow: 'rgba(156,163,175,0.2)' },
};

function getAccent(category: { color?: { badge?: string } }) {
  return accentByBadge[category?.color?.badge ?? ''] ?? accentByBadge.blue;
}
---

<div class="cat-grid">
  {categories.map((cat) => {
    const acc = getAccent(cat);
    return (
      <a
        class="cat-card"
        href={`/${cat.slug}`}
        style={`--accent: ${acc.color}; --glow: ${acc.glow};`}
      >
        <div class="cat-top">
          <span class="cat-icon">{cat.icon || '📁'}</span>
          <span class="cat-name">{cat.name}</span>
          <span class="cat-count">{cat.sections?.length ?? 0}</span>
        </div>
        {cat.sections && cat.sections.length > 0 && (
          <div class="cat-sections">
            {cat.sections.slice(0, 4).map((sec) => (
              <span class="sec-chip">{sec.icon} {sec.name}</span>
            ))}
            {cat.sections.length > 4 && (
              <span class="sec-chip sec-more">+{cat.sections.length - 4}</span>
            )}
          </div>
        )}
        <div class="cat-arrow">
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    );
  })}
</div>

<style>
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
  }

  .cat-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 18px 16px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-left: 3px solid var(--accent);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .cat-card:hover {
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.1), 0 8px 24px var(--glow);
    transform: translateY(-2px);
  }

  .cat-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cat-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .cat-name {
    flex: 1;
    font-size: 0.9rem;
    font-weight: 600;
    color: #e2e8f0;
    letter-spacing: 0.01em;
  }

  .cat-count {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    padding: 2px 7px;
    border-radius: 20px;
    flex-shrink: 0;
  }

  .cat-sections {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .sec-chip {
    font-size: 0.7rem;
    color: rgba(148,163,184,0.8);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 3px 8px;
    border-radius: 5px;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .cat-card:hover .sec-chip {
    color: rgba(203,213,225,0.9);
  }

  .sec-more {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .cat-arrow {
    position: absolute;
    right: 14px;
    bottom: 16px;
    color: rgba(100,116,139,0.5);
    transition: color 0.2s, transform 0.2s;
  }

  .cat-card:hover .cat-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
    .cat-sections { display: none; }
  }

  @media (max-width: 400px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
