---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import HubCategorias from '../components/hub-categorias.astro';
import HubCertificaciones from '../components/hub-certificaciones.astro';
import searchData from '../../public/search-index.json';

const recentPages = searchData.pages.slice(-8).reverse();
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Mi Base de Conocimiento</title>
    <meta name="description" content="Dashboard personal de estudios y conocimiento técnico">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Knowledge Base">
  <meta property="og:url" content="https://kb.villaarreola.com/">
  <meta property="og:title" content="Dashboard | Knowledge Base">
  <meta property="og:description" content="Base de conocimiento técnico personal sobre redes, sistemas, ciberseguridad, cloud y programación.">
  <meta property="og:image" content="https://kb.villaarreola.com/android-chrome-512x512.png">
  <meta property="og:image:width" content="512">
  <meta property="og:image:height" content="512">
  <meta property="og:locale" content="es_ES">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Dashboard | Knowledge Base">
  <meta name="twitter:description" content="Base de conocimiento técnico personal sobre redes, sistemas, ciberseguridad, cloud y programación.">
  <meta name="twitter:image" content="https://kb.villaarreola.com/android-chrome-512x512.png">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body>
    <Navbar />

    <div class="page-wrapper">
        <main class="main-content">

            <!-- ── Filter bar: view toggle + tag chips ── -->
            <div class="filter-bar">
              <div class="view-toggle">
                <button class="toggle-btn active" data-tab="categories">📚 Categorías</button>
                <button class="toggle-btn" data-tab="certifications">🎓 Paths</button>
              </div>
              <div class="filter-sep"></div>
              <div id="tagChips" class="tag-chips-row">
                <span class="tags-loading">cargando…</span>
              </div>
            </div>

            <!-- ── Main tab content (cards) ── -->
            <div id="tabContent" class="tab-content">
              <div id="categories-tab" class="tab-panel active">
                <HubCategorias />
              </div>
              <div id="certifications-tab" class="tab-panel">
                <HubCertificaciones />
              </div>
            </div>

            <!-- ── Filtered results (shown when tag active) ── -->
            <div id="filteredResults" class="filtered-results" style="display:none">
              <div class="filter-header">
                <span id="filterLabel" class="filter-label-text"></span>
                <button id="clearFilter" class="clear-filter-btn">✕ Quitar filtro</button>
              </div>
              <div id="filteredGrid" class="filtered-grid"></div>
            </div>

            <!-- ── Recent Pages ── -->
            <section class="recent-section" id="recentSection">
                <h2 class="recent-title">Añadido recientemente</h2>
                <div class="recent-grid">
                    {recentPages.map(page => (
                        <a href={page.url} class="recent-card">
                            <span class="r-icon">{page.icon}</span>
                            <div class="r-body">
                                <span class="r-name">{page.title}</span>
                                <span class="r-desc">{page.description}</span>
                            </div>
                            <span class="r-badge">{page.category}</span>
                        </a>
                    ))}
                </div>
            </section>
        </main>
    </div>

    <Footer />

<script>
let searchIndex: Array<{
  url: string; title: string; icon: string; description: string; category: string;
  tags?: string[];
  certifications?: Array<{ code: string }>;
}> = [];
let activeTag: string | null = null;
let activeView = 'categories';

// ── Load index & render tag chips ─────────────────────────────────────────
async function init() {
  try {
    const res = await fetch('/search-index.json');
    const data = await res.json();
    searchIndex = data.pages;

    const freq: Record<string, number> = {};
    searchIndex.forEach(p => p.tags?.forEach((t: string) => { freq[t] = (freq[t] || 0) + 1; }));
    const top = Object.entries(freq).sort((a, b) => b[1] - a[1]).slice(0, 20).map(([t]) => t);

    const palette = [
      { color: '#93c5fd', bg: 'rgba(59,130,246,0.12)',  border: 'rgba(59,130,246,0.30)',  activeColor: '#bfdbfe', activeBg: 'rgba(59,130,246,0.25)',  activeBorder: 'rgba(59,130,246,0.55)'  },
      { color: '#c4b5fd', bg: 'rgba(139,92,246,0.12)', border: 'rgba(139,92,246,0.30)', activeColor: '#ddd6fe', activeBg: 'rgba(139,92,246,0.25)', activeBorder: 'rgba(139,92,246,0.55)' },
      { color: '#6ee7b7', bg: 'rgba(16,185,129,0.12)',  border: 'rgba(16,185,129,0.30)',  activeColor: '#a7f3d0', activeBg: 'rgba(16,185,129,0.25)',  activeBorder: 'rgba(16,185,129,0.55)'  },
      { color: '#fcd34d', bg: 'rgba(245,158,11,0.12)',  border: 'rgba(245,158,11,0.30)',  activeColor: '#fde68a', activeBg: 'rgba(245,158,11,0.25)',  activeBorder: 'rgba(245,158,11,0.55)'  },
      { color: '#f9a8d4', bg: 'rgba(236,72,153,0.12)',  border: 'rgba(236,72,153,0.30)',  activeColor: '#fbcfe8', activeBg: 'rgba(236,72,153,0.25)',  activeBorder: 'rgba(236,72,153,0.55)'  },
      { color: '#67e8f9', bg: 'rgba(6,182,212,0.12)',   border: 'rgba(6,182,212,0.30)',   activeColor: '#a5f3fc', activeBg: 'rgba(6,182,212,0.25)',   activeBorder: 'rgba(6,182,212,0.55)'   },
      { color: '#fdba74', bg: 'rgba(251,146,60,0.12)',  border: 'rgba(251,146,60,0.30)',  activeColor: '#fed7aa', activeBg: 'rgba(251,146,60,0.25)',  activeBorder: 'rgba(251,146,60,0.55)'  },
    ];

    const container = document.getElementById('tagChips')!;
    container.innerHTML = '';
    top.forEach((tag, i) => {
      const p = palette[i % palette.length];
      const btn = document.createElement('button');
      btn.className = 'tag-chip';
      const tagIcon = `<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;margin-right:3px;opacity:0.75"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`;
      btn.innerHTML = `${tagIcon}${tag}`;
      btn.dataset.tag = tag;
      btn.style.setProperty('--tc', p.color);
      btn.style.setProperty('--tb', p.bg);
      btn.style.setProperty('--tbd', p.border);
      btn.style.setProperty('--tca', p.activeColor);
      btn.style.setProperty('--tba', p.activeBg);
      btn.style.setProperty('--tbda', p.activeBorder);
      btn.addEventListener('click', () => toggleTag(tag, btn));
      container.appendChild(btn);
    });
  } catch (_) {
    const container = document.getElementById('tagChips');
    if (container) container.innerHTML = '';
  }
}

// ── Tag filter ────────────────────────────────────────────────────────────
function toggleTag(tag: string, btn: HTMLButtonElement) {
  if (activeTag === tag) {
    clearFilter();
    return;
  }
  activeTag = tag;

  document.querySelectorAll('.tag-chip').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  const results = searchIndex.filter(p => p.tags?.includes(tag));
  showFiltered(results, `#${tag}`);
}

function showFiltered(pages: typeof searchIndex, label: string) {
  const tabContent = document.getElementById('tabContent')!;
  const filteredResults = document.getElementById('filteredResults')!;
  const grid = document.getElementById('filteredGrid')!;
  const labelEl = document.getElementById('filterLabel')!;

  tabContent.style.display = 'none';

  labelEl.textContent = `${pages.length} página${pages.length !== 1 ? 's' : ''} con ${label}`;
  grid.innerHTML = '';

  const catColors: Record<string, { color: string; glow: string }> = {
    ciberseguridad: { color: '#f87171', glow: 'rgba(248,113,113,0.15)' },
    redes:          { color: '#60a5fa', glow: 'rgba(96,165,250,0.15)'  },
    sistemas:       { color: '#a78bfa', glow: 'rgba(167,139,250,0.15)' },
    programacion:   { color: '#34d399', glow: 'rgba(52,211,153,0.15)'  },
    cloud:          { color: '#38bdf8', glow: 'rgba(56,189,248,0.15)'  },
    arduino:        { color: '#fb923c', glow: 'rgba(251,146,60,0.15)'  },
    datacenters:    { color: '#94a3b8', glow: 'rgba(148,163,184,0.15)' },
    robotica:       { color: '#f472b6', glow: 'rgba(244,114,182,0.15)' },
  };

  if (pages.length === 0) {
    grid.innerHTML = '<p class="no-results-msg">No hay páginas con este tag.</p>';
  } else {
    pages.forEach(page => {
      const acc = catColors[page.category] ?? { color: '#93c5fd', glow: 'rgba(59,130,246,0.15)' };
      const a = document.createElement('a');
      a.href = page.url;
      a.className = 'recent-card';
      a.style.borderLeftColor = acc.color;
      a.style.setProperty('--card-glow', acc.glow);
      a.innerHTML = `
        <span class="r-icon">${page.icon}</span>
        <div class="r-body">
          <span class="r-name">${page.title}</span>
          <span class="r-desc">${page.description || ''}</span>
        </div>
        <span class="r-badge" style="color:${acc.color};border-color:color-mix(in srgb,${acc.color} 30%,transparent);background:color-mix(in srgb,${acc.color} 10%,transparent)">${page.category}</span>
      `;
      grid.appendChild(a);
    });
  }

  filteredResults.style.display = 'block';
}

function clearFilter() {
  activeTag = null;
  document.querySelectorAll('.tag-chip').forEach(b => b.classList.remove('active'));
  document.getElementById('filteredResults')!.style.display = 'none';
  document.getElementById('tabContent')!.style.display = '';
}

// ── Tab switching ─────────────────────────────────────────────────────────
function switchTab(name: string) {
  activeView = name;
  document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelector<HTMLElement>(`[data-tab="${name}"]`)!.classList.add('active');
  document.getElementById(`${name}-tab`)!.classList.add('active');
}

// ── Boot ──────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  init();

  document.querySelectorAll('.toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => switchTab(btn.getAttribute('data-tab')!));
  });

  document.getElementById('clearFilter')!.addEventListener('click', clearFilter);
});
</script>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        background:
            repeating-linear-gradient(45deg, transparent, transparent 2px, rgba(255,255,255,0.03) 2px, rgba(255,255,255,0.03) 4px),
            linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .page-wrapper { min-height: calc(100vh - 64px); }

    .main-content {
        padding: 28px 40px 48px;
        max-width: 960px;
        margin: 0 auto;
    }

    /* ── Filter bar ── */
    .filter-bar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
    }

    .view-toggle {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
    }

    .toggle-btn {
        padding: 5px 13px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.10);
        background: transparent;
        color: rgba(148,163,184,0.7);
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .toggle-btn:hover {
        background: rgba(255,255,255,0.06);
        color: #e2e8f0;
    }

    .toggle-btn.active {
        background: rgba(255,255,255,0.10);
        border-color: rgba(255,255,255,0.22);
        color: #f1f5f9;
    }

    .filter-sep {
        width: 1px;
        height: 18px;
        background: rgba(255,255,255,0.10);
        flex-shrink: 0;
    }

    .tag-chips-row {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        flex: 1;
    }

    .tags-loading {
        font-size: 0.75rem;
        color: rgba(148,163,184,0.3);
    }

    :global(.tag-chip) {
        padding: 4px 10px;
        border-radius: 20px;
        border: 1px solid var(--tbd, rgba(255,255,255,0.08));
        background: var(--tb, transparent);
        color: var(--tc, rgba(148,163,184,0.65));
        font-size: 0.72rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
        opacity: 0.75;
    }

    :global(.tag-chip:hover) {
        opacity: 1;
        filter: brightness(1.15);
    }

    :global(.tag-chip.active) {
        background: var(--tba, rgba(59,130,246,0.22));
        color: var(--tca, #bfdbfe);
        border-color: var(--tbda, rgba(59,130,246,0.55));
        opacity: 1;
        font-size: 0.82rem;
        font-weight: 700;
        padding: 5px 13px;
        box-shadow: 0 0 10px color-mix(in srgb, var(--tbd, rgba(59,130,246,0.55)) 50%, transparent);
    }

    /* ── Tab panels ── */
    .tab-content { margin-bottom: 40px; }
    .tab-panel { display: none; }
    .tab-panel.active {
        display: block;
        animation: fadeUp 0.25s ease-out;
    }
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Filtered results ── */
    .filtered-results { margin-bottom: 40px; }

    .filter-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .filter-label-text {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(148,163,184,0.5);
    }

    .clear-filter-btn {
        background: transparent;
        border: 1px solid rgba(255,255,255,0.10);
        color: rgba(148,163,184,0.6);
        font-size: 0.72rem;
        padding: 3px 10px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.15s;
    }
    .clear-filter-btn:hover {
        background: rgba(255,255,255,0.06);
        color: #f1f5f9;
    }

    .filtered-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 8px;
    }

    .no-results-msg {
        color: rgba(148,163,184,0.5);
        font-size: 0.85rem;
    }

    /* ── Recent section ── */
    .recent-section {
        margin-top: 8px;
        padding-top: 28px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .recent-title {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.5);
        margin-bottom: 12px;
    }

    .recent-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 8px;
    }

    .recent-card {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-left: 3px solid rgba(255,255,255,0.07);
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    }

    .recent-card:hover {
        background: rgba(255,255,255,0.055);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px var(--card-glow, rgba(0,0,0,0.2));
    }

    .r-icon { font-size: 1.2rem; flex-shrink: 0; }

    .r-body { display: flex; flex-direction: column; flex: 1; min-width: 0; }

    .r-name {
        font-size: 0.82rem;
        font-weight: 600;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .r-desc {
        font-size: 0.72rem;
        color: rgba(148, 163, 184, 0.7);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .r-badge {
        font-size: 0.65rem;
        font-weight: 600;
        color: rgba(100, 116, 139, 0.8);
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.07);
        padding: 2px 6px;
        border-radius: 4px;
        flex-shrink: 0;
        align-self: flex-start;
    }

      /* Dynamic cards in #filteredGrid are created by JS and need global selectors */
      :global(#filteredGrid .recent-card) {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-left: 3px solid rgba(255,255,255,0.07);
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
      }

      :global(#filteredGrid .recent-card:hover) {
        background: rgba(255,255,255,0.055);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px var(--card-glow, rgba(0,0,0,0.2));
      }

      :global(#filteredGrid .r-icon) {
        font-size: 1.2rem;
        flex-shrink: 0;
      }

      :global(#filteredGrid .r-body) {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
      }

      :global(#filteredGrid .r-name) {
        font-size: 0.82rem;
        font-weight: 600;
        color: #e2e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      :global(#filteredGrid .r-desc) {
        font-size: 0.72rem;
        color: rgba(148, 163, 184, 0.7);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      :global(#filteredGrid .r-badge) {
        font-size: 0.65rem;
        font-weight: 600;
        color: rgba(100, 116, 139, 0.8);
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.07);
        padding: 2px 6px;
        border-radius: 4px;
        flex-shrink: 0;
        align-self: flex-start;
      }

    @media (max-width: 768px) {
        .main-content { padding: 20px 20px 32px; }
        .filter-sep { display: none; }
    }

    @media (max-width: 640px) {
        .recent-grid, .filtered-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
        .main-content { padding: 16px 12px 24px; }
    }
</style>

</body>
</html>
