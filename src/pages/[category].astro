---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import siteConfig from '../data/site-config.json';

export function getStaticPaths() {
  return (siteConfig.categories || []).map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;

const title = `${category.icon || '📁'} ${category.name} - Índice de Temas`;
const categorySlug = category.slug;
const sectionMeta = category.sections || [];
const accentBadge = category?.color?.badge || 'gray';
const headerGradient = category?.color?.headerGradient || 'from-gray-600 to-gray-700';

const accentColorMap = {
  indigo: '#818cf8',
  blue: '#60a5fa',
  slate: '#94a3b8',
  green: '#4ade80',
  orange: '#fb923c',
  gray: '#9ca3af',
  purple: '#c084fc',
  red: '#f87171',
  yellow: '#facc15',
  pink: '#f472b6',
  cyan: '#22d3ee',
  teal: '#2dd4bf',
  amber: '#fbbf24',
};
const accentHex = accentColorMap[accentBadge] || '#9ca3af';
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Knowledge Base</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.classList.toggle('dark', t === 'dark');
    })();
  </script>
  <style>
    body { font-family: 'Outfit', 'Segoe UI', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    .topic-arrow { transition: transform 0.15s ease, color 0.15s ease; }
    .topic-link:hover .topic-arrow { transform: translateX(4px); color: var(--accent-color); }
    .section-card {
      border-left: 4px solid var(--accent-color);
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }
    .section-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.07);
    }
    @keyframes skeleton-shimmer { 0%, 100% { opacity: 0.4; } 50% { opacity: 0.9; } }
    .skeleton-bar { animation: skeleton-shimmer 1.5s ease-in-out infinite; }
  </style>
</head>
<body>
  <Navbar />

  <main class="min-h-screen bg-slate-950 text-slate-100" style={`--accent-color: ${accentHex}`}>

    <!-- Hero -->
    <section class={`relative overflow-hidden bg-gradient-to-r ${headerGradient} border-b border-white/10`}>
      <!-- Dot pattern -->
      <div class="absolute inset-0 opacity-[0.15]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 22px 22px;"></div>
      <!-- Depth overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-black/0 to-black/30"></div>

      <div class="relative max-w-6xl mx-auto px-6 py-6 md:py-9 flex items-center justify-between gap-8">
        <div class="flex-1 min-w-0">
          <div class="inline-flex items-center gap-1.5 rounded-full bg-white/10 border border-white/20 px-3 py-1 text-xs font-medium text-white/80">
            <span>{category.icon || '📁'}</span>
            <span>Knowledge Base</span>
          </div>
          <h1 class="mt-2 text-3xl md:text-4xl font-extrabold tracking-tight text-white">{category.name}</h1>
          <p class="mt-2 text-white/70 text-sm leading-relaxed">
            Contenido de <strong class="text-white/90">{category.name}</strong> generado desde Notion.
          </p>
          <div class="mt-4 flex items-center gap-6">
            <div>
              <p id="topics-count" class="text-2xl font-bold text-white">-</p>
              <p class="text-xs text-white/55 uppercase tracking-widest mt-0.5">Temas</p>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div>
              <p id="sections-count" class="text-2xl font-bold text-white">-</p>
              <p class="text-xs text-white/55 uppercase tracking-widest mt-0.5">Secciones</p>
            </div>
          </div>
        </div>
        <!-- Decorative icon -->
        <div class="hidden md:block text-[5rem] leading-none opacity-10 select-none" aria-hidden="true">{category.icon || '📁'}</div>
      </div>
    </section>

    <!-- Content grid -->
    <section class="max-w-6xl mx-auto px-6 py-6 md:py-8">
      <div id="category-index" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Skeleton loading -->
        <div class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
          <div class="skeleton-bar h-5 bg-slate-700 rounded w-2/5 mb-5"></div>
          <div class="space-y-3">
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-4/5"></div>
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-3/5" style="animation-delay:0.2s"></div>
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-2/3" style="animation-delay:0.4s"></div>
          </div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
          <div class="skeleton-bar h-5 bg-slate-700 rounded w-1/2 mb-5"></div>
          <div class="space-y-3">
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-3/4" style="animation-delay:0.1s"></div>
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-1/2" style="animation-delay:0.3s"></div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <script define:vars={{ categorySlug, sectionMeta }}>
    const indexContainer = document.getElementById('category-index');
    const topicsCountEl = document.getElementById('topics-count');
    const sectionsCountEl = document.getElementById('sections-count');

    const sectionMap = new Map((sectionMeta || []).map((s) => [s.slug, s]));

    function byColumnThenName(a, b) {
      const colA = a.column || 2;
      const colB = b.column || 2;
      if (colA !== colB) return colA - colB;
      return (a.name || '').localeCompare(b.name || '');
    }

    function renderSection(section) {
      const topicItems = section.topics.map((topic) => {
        const safeTitle = String(topic.title || topic.slug || 'Tema');
        const safeUrl = String(topic.url || '#');
        return `
          <li class="border-b border-white/10 last:border-b-0">
            <a href="${safeUrl}" class="topic-link flex items-center justify-between py-2 text-slate-300 hover:text-white transition-colors duration-150">
              <span class="truncate pr-2">${safeTitle}</span>
              <span class="topic-arrow text-slate-500 shrink-0">→</span>
            </a>
          </li>
        `;
      }).join('');

      const descHtml = section.description
        ? `<p class="text-xs text-slate-400 mt-1 mb-3 leading-snug">${section.description}</p>`
        : '';
      return `
        <article class="section-card rounded-2xl border border-white/10 bg-slate-900/60 hover:bg-slate-900/80 hover:border-white/20 p-6 transition-all duration-200">
          <div class="flex items-center justify-between gap-3 mb-3">
            <h3 class="text-lg font-bold text-white">${section.icon || '📄'} ${section.name || section.slug}</h3>
            <span class="text-xs text-slate-400 bg-slate-800/80 px-2.5 py-1 rounded-full shrink-0">${section.topics.length} temas</span>
          </div>
          ${descHtml}<ul>${topicItems}</ul>
        </article>
      `;
    }

    async function buildCategoryIndex() {
      try {
        const response = await fetch('/search-index.json');
        const payload = await response.json();
        const allPages = payload.pages || [];

        const pages = allPages.filter((page) => {
          const url = String(page.url || '').toLowerCase();
          return url.startsWith(`/${String(categorySlug).toLowerCase()}/`);
        });

        topicsCountEl.textContent = String(pages.length);

        if (pages.length === 0) {
          sectionsCountEl.textContent = '0';
          indexContainer.innerHTML = `
            <article class="md:col-span-2 rounded-2xl border border-amber-400/20 bg-amber-500/5 p-8 text-center">
              <div class="text-5xl mb-4">📭</div>
              <h3 class="text-xl font-semibold text-amber-200 mb-2">Sin temas publicados</h3>
              <p class="text-amber-100/70 max-w-md mx-auto">
                No hay contenido indexado todavía para esta categoría.
                Los temas aparecerán aquí cuando se publiquen desde Notion.
              </p>
            </article>
          `;
          return;
        }

        const grouped = new Map();
        for (const page of pages) {
          const sectionSlug = String(page.section || 'fundamentos').toLowerCase();
          if (!grouped.has(sectionSlug)) grouped.set(sectionSlug, []);
          grouped.get(sectionSlug).push(page);
        }

        const sections = Array.from(grouped.entries()).map(([slug, entries]) => {
          const meta = sectionMap.get(slug) || {
            slug,
            name: slug.charAt(0).toUpperCase() + slug.slice(1),
            icon: '📄',
            column: 2,
          };
          return {
            ...meta,
            topics: entries.sort((a, b) => String(a.title || '').localeCompare(String(b.title || ''))),
          };
        }).sort(byColumnThenName);

        sectionsCountEl.textContent = String(sections.length);
        indexContainer.innerHTML = sections.map(renderSection).join('');
      } catch (error) {
        indexContainer.innerHTML = `
          <article class="md:col-span-2 rounded-2xl border border-red-400/20 bg-red-500/5 p-6">
            <h3 class="text-lg font-semibold text-red-200">Error cargando índice</h3>
            <p class="mt-2 text-red-100/70">${error.message}</p>
          </article>
        `;
      }
    }

    buildCategoryIndex();
  </script>
</body>
</html>
