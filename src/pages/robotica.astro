---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import siteConfig from "../data/site-config.json";

const roboticaConfig = (siteConfig.categories || []).find((c) => c.slug === "robotica");
const sectionMeta = roboticaConfig?.sections || [];

const title = "🤖 Robótica - Índice de Temas";
const description = "Robótica, automatización, inteligencia artificial aplicada y programación de sistemas embebidos.";
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Knowledge Base</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .topic-arrow { transition: transform 0.15s ease, color 0.15s ease; }
    .topic-link:hover .topic-arrow { transform: translateX(4px); color: #c084fc; }
    .section-card { border-left: 4px solid #c084fc; transition: transform 0.2s ease; }
    .section-card:hover { transform: translateY(-2px); }
    @keyframes skeleton-shimmer { 0%, 100% { opacity: 0.4; } 50% { opacity: 0.9; } }
    .skeleton-bar { animation: skeleton-shimmer 1.5s ease-in-out infinite; }
  </style>
</head>
<body>
  <Navbar />

  <main class="min-h-screen bg-slate-950 text-slate-100">

    <!-- Hero -->
    <section class="relative overflow-hidden bg-gradient-to-r from-purple-600 to-violet-700 border-b border-white/10">
      <!-- Grid pattern -->
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"
      ></div>
      <!-- Depth overlay -->
      <div class="absolute inset-0 bg-gradient-to-b from-black/0 to-black/30"></div>

      <div class="relative max-w-6xl mx-auto px-6 py-14 md:py-20 flex items-center justify-between gap-10">
        <div class="flex-1 min-w-0">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/15 border border-white/25 backdrop-blur-sm px-4 py-1.5 text-sm font-medium text-white/90">
            <span>🤖</span>
            <span>Knowledge Base</span>
          </div>
          <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-white">Robótica</h1>
          <p class="mt-3 text-white/75 max-w-2xl text-base leading-relaxed">{description}</p>
          <div class="mt-7 flex items-center gap-8">
            <div>
              <p id="topics-count" class="text-3xl font-bold text-white">-</p>
              <p class="text-xs text-white/55 uppercase tracking-widest mt-0.5">Temas</p>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div>
              <p id="sections-count" class="text-3xl font-bold text-white">-</p>
              <p class="text-xs text-white/55 uppercase tracking-widest mt-0.5">Secciones</p>
            </div>
          </div>
        </div>
        <!-- Decorative icon -->
        <div class="hidden md:block text-[7rem] leading-none opacity-15 select-none" aria-hidden="true">🤖</div>
      </div>
    </section>

    <!-- Content grid -->
    <section class="max-w-6xl mx-auto px-6 py-10 md:py-14">
      <div id="robotica-index" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Skeleton loading -->
        <div class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
          <div class="skeleton-bar h-5 bg-slate-700 rounded w-2/5 mb-5"></div>
          <div class="space-y-3">
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-4/5"></div>
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-3/5" style="animation-delay:0.2s"></div>
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-2/3" style="animation-delay:0.4s"></div>
          </div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
          <div class="skeleton-bar h-5 bg-slate-700 rounded w-1/2 mb-5"></div>
          <div class="space-y-3">
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-3/4" style="animation-delay:0.1s"></div>
            <div class="skeleton-bar h-3.5 bg-slate-700/60 rounded w-1/2" style="animation-delay:0.3s"></div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <script define:vars={{ sectionMeta }}>
    const indexContainer = document.getElementById('robotica-index');
    const topicsCountEl = document.getElementById('topics-count');
    const sectionsCountEl = document.getElementById('sections-count');

    const sectionMap = new Map((sectionMeta || []).map((s) => [s.slug, s]));

    function byColumnThenName(a, b) {
      const colA = a.column || 2;
      const colB = b.column || 2;
      if (colA !== colB) return colA - colB;
      return (a.name || '').localeCompare(b.name || '');
    }

    function renderSection(section) {
      const topicItems = section.topics.map((topic) => {
        const safeTitle = String(topic.title || topic.slug || 'Tema');
        const safeUrl = String(topic.url || '#');
        return `
          <li class="border-b border-white/10 last:border-b-0">
            <a href="${safeUrl}" class="topic-link flex items-center justify-between py-2.5 text-slate-300 hover:text-white transition-colors duration-150">
              <span class="truncate pr-2">${safeTitle}</span>
              <span class="topic-arrow text-slate-500 shrink-0">→</span>
            </a>
          </li>
        `;
      }).join('');

      return `
        <article class="section-card rounded-2xl border border-white/10 bg-slate-900/70 p-6">
          <div class="flex items-center justify-between gap-3 mb-4">
            <h3 class="text-lg font-bold text-white">${section.icon || '📄'} ${section.name || section.slug}</h3>
            <span class="text-xs text-slate-400 bg-slate-800/80 px-2.5 py-1 rounded-full shrink-0">${section.topics.length} temas</span>
          </div>
          <ul>${topicItems}</ul>
        </article>
      `;
    }

    async function buildIndex() {
      try {
        const response = await fetch('/search-index.json');
        const payload = await response.json();
        const pages = (payload.pages || []).filter((p) =>
          String(p.url || '').toLowerCase().startsWith('/robotica/')
        );

        topicsCountEl.textContent = String(pages.length);

        if (pages.length === 0) {
          sectionsCountEl.textContent = '0';
          indexContainer.innerHTML = `
            <article class="md:col-span-2 rounded-2xl border border-purple-400/20 bg-purple-500/5 p-8 text-center">
              <div class="text-5xl mb-4">🤖</div>
              <h3 class="text-xl font-semibold text-purple-200 mb-2">Sin temas publicados</h3>
              <p class="text-purple-100/70 max-w-md mx-auto">
                No hay contenido indexado todavía para Robótica.
                Los temas aparecerán aquí cuando se publiquen desde Notion.
              </p>
            </article>
          `;
          return;
        }

        const grouped = new Map();
        for (const page of pages) {
          const sectionSlug = String(page.section || 'fundamentos').toLowerCase();
          if (!grouped.has(sectionSlug)) grouped.set(sectionSlug, []);
          grouped.get(sectionSlug).push(page);
        }

        const sections = Array.from(grouped.entries()).map(([slug, entries]) => {
          const meta = sectionMap.get(slug) || {
            slug,
            name: slug.charAt(0).toUpperCase() + slug.slice(1),
            icon: '📄',
            column: 2,
          };
          return {
            ...meta,
            topics: entries.sort((a, b) => String(a.title || '').localeCompare(String(b.title || ''))),
          };
        }).sort(byColumnThenName);

        sectionsCountEl.textContent = String(sections.length);
        indexContainer.innerHTML = sections.map(renderSection).join('');
      } catch (error) {
        indexContainer.innerHTML = `
          <article class="md:col-span-2 rounded-2xl border border-red-400/20 bg-red-500/5 p-6">
            <h3 class="text-lg font-semibold text-red-200">Error cargando índice</h3>
            <p class="mt-2 text-red-100/70">${error.message}</p>
          </article>
        `;
      }
    }

    buildIndex();
  </script>
</body>
</html>
