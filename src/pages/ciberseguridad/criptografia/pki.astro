</style>

<script>
  const dots = document.querySelectorAll<HTMLButtonElement>('.ep-csr-dot');
  const cards = document.querySelectorAll<HTMLElement>('.ep-csr-card');
  const prevBtn = document.getElementById('ep-csr-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('ep-csr-next') as HTMLButtonElement | null;
  const counter = document.getElementById('ep-csr-counter');
  const total = cards.length;
  let current = 0;

  function goTo(n: number) {
    dots[current].classList.remove('active');
    if (n > current) dots[current].classList.add('done');
    cards[current].classList.remove('active');
    current = n;
    dots[current].classList.remove('done');
    dots[current].classList.add('active');
    cards[current].classList.add('active');
    if (counter) counter.textContent = `Paso ${current + 1} de ${total}`;
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current === total - 1;
    // update done states
    dots.forEach((dot, i) => {
      if (i < current) dot.classList.add('done');
      else dot.classList.remove('done');
    });
  }

  prevBtn?.addEventListener('click', () => { if (current > 0) goTo(current - 1); });
  nextBtn?.addEventListener('click', () => { if (current < total - 1) goTo(current + 1); });
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i));
  });
</script>
